{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "esnext",
    "sourceMap": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": ["node", "jest"],
    "paths": {
      "@constants": ["./src/constants/index.ts"],
      "@modules/*": ["./src/modules/*"],
      "@problems/exceptions": ["./src/problems/exceptions/index.ts"],
      "@problems/filters": ["./src/problems/filters/index.ts"],
      "@problems/responses": ["./src/problems/responses/index.ts"]
    }
  }
}
