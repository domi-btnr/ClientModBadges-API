{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "esnext",
    "sourceMap": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": ["node", "jest"],
    "paths": {
      "@modules/*": ["./src/modules/*"],
      "@problems/dto": ["./src/problems/dto/index.ts"],
      "@problems/exception": ["./src/problems/exception/index.ts"],
      "@problems/filter": ["./src/problems/filter/index.ts"],
      "@problems/response": ["./src/problems/response/index.ts"],
      "@providers/*": ["./src/providers/*"],
      "@utils": ["./src/utils/index.ts"]
    }
  }
}
